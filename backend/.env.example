# Example env for local development - DO NOT COMMIT secrets
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword
POSTGRES_DB=appdb
DATABASE_URL=postgresql://appuser:apppassword@db:5432/appdb
JWT_SECRET=replace-with-a-strong-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
OPENAI_API_KEY=API_KEY
GOOGLE_OAUTH_CLIENT_SECRETS_FILE=/secrets/client_secret.json
GOOGLE_CALENDAR_API_KEY=API_KEY
GOOGLE_REDIRECT_URI=http://localhost:8000/google/callback

# Microsoft Graph API (delegated user OAuth - mirrors Google flow)
# Register an app in Azure AD (https://portal.azure.com -> App registrations),
# then:
#   1. Add a Web platform redirect URI matching MS_REDIRECT_URI below.
#   2. Under "API permissions", add Microsoft Graph delegated permissions:
#        - User.Read
#        - Calendars.Read
#      then grant admin consent for the tenant.
#   3. Under "Certificates & secrets", create a client secret and paste below.
MS_TENANT_ID=common
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://localhost:8000/microsoft/callback